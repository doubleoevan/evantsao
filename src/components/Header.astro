---
import { cn } from "../lib/utils.ts";
import Logo from "../components/Logo.astro";
import { ThemeButton } from "./ThemeButton.tsx";
import { MenuButton } from "./MenuButton.tsx";

const { class: className = "" } = Astro.props;

const menuLinkClass = `
  relative inline-block
  after:absolute after:left-0 after:bottom-0
  after:h-0.5 after:w-0 after:bg-primary
  after:transition-all after:duration-300
  hover:after:w-full
  hover:text-primary
`;

const activeLinkClass = `
  after:w-full
  text-primary
`;

function toLinkClass(href) {
  const pathname = Astro.url.pathname;
  return cn(menuLinkClass, pathname === href && activeLinkClass);
}
---

<header class={cn("p-4 flex items-center justify-between", className)}>
  <a class="flex gap-2 text-xl text-primary" href="/">
    <Logo /> Evan Tsao
  </a>
  <nav aria-label="Primary" class="flex justify-end gap-2 sm:gap-4! items-center">
    <ul id="primary-menu" class="hidden sm:flex! justify-end gap-6">
      <li>
        <a class={toLinkClass("/")} href="/">Home</a>
      </li>
      <li>
        <a class={toLinkClass("/writing")} href="/writing">Writing</a>
      </li>
      <li>
        <a class={toLinkClass("/music")} href="/music">Music</a>
      </li>
      <li>
        <a class={toLinkClass("/improv")} href="/improv">Improv</a>
      </li>
      <li>
        <a class={toLinkClass("/technology")} href="/technology">Technology</a>
      </li>
    </ul>
    <ThemeButton client:load />
    <MenuButton className="visible sm:hidden!" client:load />
  </nav>
</header>
