---
import { cn } from "../lib/utils.ts";
import { Github, Linkedin } from "lucide-react";
const { class: className = "" } = Astro.props;
---

<footer class={cn("p-4 flex items-center justify-between", className)}>
  <div class="flex items-center gap-4">
    <a
      href="https://github.com/doubleoevan"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-primary transition-colors"
    >
      <Github class="size-5" />
    </a>
    <a
      href="https://linkedin.com/in/doubleoevan"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-primary transition-colors"
    >
      <Linkedin class="size-5" />
    </a>
  </div>

  <div>© 2026 Evan Tsao. Built with Astro.</div>
</footer>
