---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="flex flex-col gap-8">
    <div class="flex flex-col gap-4">
      <h1 class="text-4xl font-extrabold tracking-tight">Projects</h1>
      <p class="text-lg max-w-2xl">
        Here are some of the projects I have worked on. I am always looking for new challenges and
        opportunities to learn and grow as a developer. If you have a project in mind, feel free to
        reach out! 🙂
      </p>
    </div>
    <div class="flex flex-col gap-4">
      <h2 class="text-3xl font-extrabold">Skills & Technologies</h2>
      <p class="text-lg">These are some of the technologies I've been working with...</p>
    </div>
  </section>
</Layout>
