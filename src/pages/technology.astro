---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
import { ExternalLink } from "lucide-react";
import { Image } from "astro:assets";
---

<Layout>
  <section class="flex flex-col gap-8 mx-auto max-w-3xl">
    <div class="flex flex-col gap-4">
      <h1 class="text-4xl font-extrabold">Projects</h1>
      <p class="text-lg max-w-2xl">
        Here are some of the projects I have worked on. I am always looking for new opportunities to
        learn and grow as a developer. If you have a project in mind, feel free to reach out. 🙂
      </p>
    </div>
    <div class="flex flex-col gap-4">
      <h2 class="text-3xl font-extrabold">Skills & Technologies</h2>
      <p class="text-lg">These are some of the technologies I've been working with...</p>
    </div>
    <ul class="flex flex-col gap-10">
      <li>
        <h2 class="text-lg font-semibold">
          <Link href="https://bookmemory.io" target="_blank" rel="noopener noreferrer">
            BookMemory - A search engine for bookmarks. 🧠✨
          </Link>
        </h2>
        <section class="flex flex-col md:flex-row! gap-4 pt-4">
          <figure class="flex flex-col items-center gap-4">
            <a href="https://bookmemory.io" target="_blank" rel="noopener noreferrer">
              <Image
                class="w-2xl aspect-3/2 object-cover rounded-xl border hover:border-primary bg-background dark:hidden"
                width={384}
                height={256}
                src="https://www.bookmemory.io/screenshots/vector_search_dark.png"
                alt="BookMemory detail view showing an AI-generated bookmark summaries, extracted descriptions, tags, and related bookmarks powered by semantic search."
              />
              <Image
                class="w-2xl aspect-3/2 object-cover rounded-xl border hover:border-primary bg-background hidden dark:block!"
                width={384}
                height={256}
                src="https://www.bookmemory.io/screenshots/vector_search_light.png"
                alt="BookMemory detail view showing an AI-generated bookmark summaries, extracted descriptions, tags, and related bookmarks powered by semantic search."
              />
            </a>
            <Link
              href="https://bookmemory.io"
              class="inline-flex items-start gap-1 text-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              https://bookmemory.io
              <ExternalLink aria-hidden="true" className="size-5" />
            </Link>
          </figure>
          <p class="max-w-xl">
            Full Stack Developer exploring AI with modern technologies. Expert in React, TypeScript,
            Node.js, Java, Python and enterprise software development, shipping projects large and
            small. 🚀
          </p>
        </section>
      </li>
      <li>
        <h2 class="text-lg font-semibold">
          <Link href="https://chatwar.ai" target="_blank" rel="noopener noreferrer">
            ChatWar - A fight club for LLMs 🤫
          </Link>
        </h2>
        <section class="flex flex-col md:flex-row! gap-4 pt-4">
          <figure class="flex flex-col items-center gap-4">
            <a
              href="https://chatwar.ai"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full max-w-2xl"
            >
              <video
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                class="w-full aspect-3/2 object-cover rounded-xl border bg-background dark:hidden"
                aria-label="ChatWar demo showing AI responses and voting"
              >
                <source src="https://chatwar.ai/demo/demo-light.mp4" type="video/mp4" />
                Your browser does not support the video tag.
              </video>

              <video
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                class="hidden w-full aspect-3/2 object-cover rounded-xl border bg-background dark:block"
                aria-label="ChatWar demo showing AI responses and voting"
              >
                <source src="https://chatwar.ai/demo/demo-dark.mp4" type="video/mp4" />
                Your browser does not support the video tag.
              </video>
            </a>
            <Link
              href="https://chatwar.ai"
              class="inline-flex items-start gap-1 text-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              https://chatwar.ai
              <ExternalLink aria-hidden="true" className="size-5" />
            </Link>
          </figure>
          <p class="max-w-xl">
            Full Stack Developer exploring AI with modern technologies. Expert in React, TypeScript,
            Node.js, Java, Python and enterprise software development, shipping projects large and
            small. 🚀
          </p>
        </section>
      </li>
    </ul>
  </section>
</Layout>
