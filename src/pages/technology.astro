---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
import { FileHeart, MessageCircleHeart, ExternalLink } from "lucide-react";
import { Image } from "astro:assets";
import { TechStacks } from "../components/TechStacks.tsx";
import TagList from "../components/TagList.astro";
---

<Layout>
  <section class="flex flex-col gap-10 mx-auto max-w-4xl">
    <div class="flex flex-col gap-4">
      <h1 class="text-4xl font-extrabold">Projects</h1>
      <p class="text-lg max-w-2xl">
        Here are some of the projects I have worked on. I am always looking for new opportunities to
        learn and grow as a developer. If you have a project in mind, feel free to reach out. 🙂
      </p>
    </div>
    <div class="flex flex-col gap-4">
      <h2 class="text-3xl font-extrabold">Skills & Technologies</h2>
      <p class="text-lg">These are some of the technologies I've been working with...</p>
      <TechStacks client:visible />
    </div>
    <ul class="flex flex-col gap-10">
      <li>
        <h2 class="text-lg font-semibold">
          <Link href="https://bookmemory.io" target="_blank" rel="noopener noreferrer">
            BookMemory - A search engine for bookmarks. 🧠✨
          </Link>
        </h2>
        <section class="flex flex-col md:flex-row! gap-4 pt-4">
          <figure class="flex flex-col items-center gap-4">
            <a
              href="https://bookmemory.io"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xl border hover:border-primary"
            >
              <Image
                class="w-2xl aspect-3/2 object-cover rounded-xl border hover:border-primary bg-background dark:hidden"
                width={384}
                height={256}
                src="https://www.bookmemory.io/screenshots/vector_search_dark.png"
                alt="BookMemory detail view showing an AI-generated bookmark summaries, extracted descriptions, tags, and related bookmarks powered by semantic search."
              />
              <Image
                class="w-2xl aspect-3/2 object-cover rounded-xl border hover:border-primary bg-background hidden dark:block!"
                width={384}
                height={256}
                src="https://www.bookmemory.io/screenshots/vector_search_light.png"
                alt="BookMemory detail view showing an AI-generated bookmark summaries, extracted descriptions, tags, and related bookmarks powered by semantic search."
              />
            </a>
            <Link
              href="https://bookmemory.io"
              class="inline-flex items-start gap-1 text-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              https://bookmemory.io
              <ExternalLink aria-hidden="true" className="size-5" />
            </Link>
          </figure>
          <div class="flex flex-col gap-4 md:max-w-xl">
            <p>
              Bookmarks that go beyond a URL and title...
              <span class="block py-2">
                This reimagined bookmark management system provides AI-generated content
                descriptions, web search summaries, and tagging. Website content is stored as vector
                embeddings to power semantic search and automatically discover related bookmarks.
              </span>
              <Link
                href="https://bookmemory.io"
                class="inline-flex items-start gap-1 text-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                BookMemory
              </Link> makes your bookmarks smarter.
              <FileHeart aria-hidden="true" className="inline size-[1em] align-text-top" />
            </p>
            <TagList
              tags={[
                "React",
                "TypeScript",
                "FastAPI",
                "Postgres",
                "pgvector",
                "Semantic Search",
                "OpenAI",
              ]}
            />
          </div>
        </section>
      </li>
      <li>
        <h2 class="text-lg font-semibold">
          <Link href="https://chatwar.ai" target="_blank" rel="noopener noreferrer">
            ChatWar - A fight club for LLMs 🤫
          </Link>
        </h2>
        <section class="flex flex-col md:flex-row! gap-4 pt-4">
          <figure class="flex flex-col items-center gap-4">
            <a
              href="https://chatwar.ai"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full max-w-2xl rounded-xl border hover:border-primary"
              aria-label="ChatWar demo showing AI responses and voting"
            >
              <video
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                class="w-full aspect-3/2 object-cover rounded-xl border hover:border-primary bg-background dark:hidden"
                aria-label="ChatWar demo showing AI responses and voting"
              >
                <source src="https://chatwar.ai/demo/demo-light.mp4" type="video/mp4" />
                Your browser does not support the video tag.
              </video>

              <video
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                class="hidden w-full aspect-3/2 object-cover rounded-xl border hover:border-primary bg-background dark:block"
                aria-label="ChatWar demo showing AI responses and voting"
              >
                <source src="https://chatwar.ai/demo/demo-dark.mp4" type="video/mp4" />
                Your browser does not support the video tag.
              </video>
            </a>
            <Link
              href="https://chatwar.ai"
              class="inline-flex items-start gap-1 text-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              https://chatwar.ai
              <ExternalLink aria-hidden="true" className="size-5" />
            </Link>
          </figure>
          <div class="flex flex-col gap-4 md:max-w-xl">
            <p>
              Which AI model should you choose?
              <span class="block py-2">
                Choose all of them. Chat with AI models simultaneously. Compare the responses. Then
                vote for your favorite one. Check out the leaderboard to see which models come out
                on top.
              </span>
              <Link
                href="https://chatwar.ai"
                class="inline-flex items-start gap-1 text-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                ChatWar</Link
              > lets you discover your favorite AI model.
              <MessageCircleHeart aria-hidden="true" className="inline size-[1em] align-text-top" />
            </p>
            <TagList tags={["React", "TypeScript", "LLMs", "Tailwind"]} />
          </div>
        </section>
      </li>
    </ul>
  </section>
</Layout>
