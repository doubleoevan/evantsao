---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
---

<Layout>
  <section class="grid gap-10 md:grid-cols-2 items-start">
    <figure class="flex justify-center md:justify-end! pt-4">
      <!-- logo / image -->
      <Logo class="w-72" />
    </figure>

    <div class="flex flex-col gap-4">
      <h1 class="text-4xl font-extrabold tracking-tight">Evan Tsao</h1>
      <p>
        <span
          class="px-4 py-1.5
            inline-flex items-center
            rounded-full text-sm font-medium
            bg-primary text-background"
        >
          I make
        </span>
        Art with Technology
        <!-- dark mode only computer sparkles -->
        <span class="relative items-center hidden dark:inline-flex">
          <!-- inner glow -->
          <span
            class="absolute -inset-1 -z-10 rounded-full blur-md
              bg-primary opacity-100
              dark:opacity-50"
          ></span>
          <!-- outer glow -->
          <span
            class="absolute -inset-4 -z-10 rounded-full blur-2xl
              bg-primary opacity-70
              dark:opacity-30"
          ></span>
          <span class="inline-block -scale-x-100">✨</span>💻✨
        </span>

        <!-- light mode only computer lightning bolts -->
        <span class="inline-flex items-center dark:hidden">
          <span class="inline-block -scale-x-100">⚡</span>💻⚡
        </span>️
      </p>

      <p class="text-lg">Full Stack Developer specializing in modern technologies...</p>
    </div>
  </section>
</Layout>
